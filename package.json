{
  "name": "spfx-parquet-viewer",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.14.0 < 23.0.0"
  },
  "scripts": {
    "build": "pnpm --dir ui build && heft test --clean --production && heft package-solution --production",
    "clean": "heft clean",
    "eject-webpack": "heft eject-webpack",
    "start": "concurrently -n ui,spfx -c cyan,magenta \"pnpm --dir ui watch\" \"heft start --clean\""
  },
  "dependencies": {
    "@microsoft/sp-component-base": "1.23.1",
    "@microsoft/sp-core-library": "1.23.1",
    "@microsoft/sp-http": "^1.23.1",
    "@microsoft/sp-lodash-subset": "1.23.1",
    "@microsoft/sp-office-ui-fabric-core": "1.23.1",
    "@microsoft/sp-property-pane": "1.23.1",
    "@microsoft/sp-webpart-base": "1.23.1",
    "tslib": "2.3.1"
  },
  "devDependencies": {
    "@fluentui/react": "^8.106.4",
    "@microsoft/eslint-config-spfx": "1.23.1",
    "@microsoft/eslint-plugin-spfx": "1.23.1",
    "@microsoft/sp-module-interfaces": "1.23.1",
    "@microsoft/spfx-heft-plugins": "1.23.1",
    "@microsoft/spfx-web-build-rig": "1.23.1",
    "@rushstack/heft": "1.2.17",
    "@types/jest": "30.0.0",
    "@types/webpack-env": "~1.15.2",
    "concurrently": "^10.0.3",
    "css-loader": "~7.1.2",
    "eslint": "9.37.0",
    "typescript": "~5.8.0"
  },
  "overrides": {
    "@rushstack/heft": "1.2.17"
  }
}
